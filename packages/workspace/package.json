  },
  "devDependencies": {
    "@mastra/core": "^1.45.0",
    "@types/dockerode": "^4.0.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "4.1.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.0",
    "vitest": "^4.1.0",
    "zod": "^4.4.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
