{
  "name": "@arivie/workspace",
  "version": "2.4.0",
  "description": "Arivie workspace — read-only SemanticLayerFilesystem over Mastra Workspace.",
  "type": "module",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
