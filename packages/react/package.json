{
  "name": "@arivie/react",
  "version": "2.2.0",
  "private": false,
  "type": "module",
  "description": "Arivie React surface — headless hooks (useAgent, useSchema, useMemory) AND a drop-in chat UI (<ArivieChat>, <ArtifactPane>) wired to the shared @arivie/ui-catalog via @json-render/react.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./chat": {
      "import": "./dist/chat/index.js",
      "types": "./dist/chat/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "echo no-lint-yet",
    "size": "size-limit",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@arivie/ui-catalog": "workspace:*",
    "@json-render/react": "^0.19.0",
    "@json-render/shadcn": "^0.19.0",
    "streamdown": "^1.5.0",
    "zod": "^4.4.0"
  },
  "peerDependencies": {
    "@ai-sdk/react": "^3.0.0",
    "ai": "^6.0.0",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/react": {
      "optional": true
    },
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/react": "^3.0.118",
    "@size-limit/preset-small-lib": "^11.1.6",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "ai": "^6.0.116",
    "happy-dom": "^15.11.7",
    "jsdom": "^26.0.0",
    "msw": "^2.8.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "size-limit": "^11.1.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.0",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
