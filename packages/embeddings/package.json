    "@mastra/core": "^1.45.0"
  },
  "devDependencies": {
    "@mastra/core": "^1.45.0",
    "@mastra/pg": "^1.14.0",
    "@testcontainers/postgresql": "^11.0.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.0",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
