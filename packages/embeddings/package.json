{
  "name": "@arivie/embeddings",
  "version": "2.3.0",
  "private": false,
  "type": "module",
  "description": "Arivie embedding providers — OpenAI, Cohere, and Voyage adapters over AI SDK v6.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
