{
  "name": "@arivie/source-mcp",
  "version": "2.1.0",
  "description": "Arivie MCP source adapter — wraps @mastra/mcp MCPClient as a SourceAdapter.",
  "type": "module",
  "license": "Apache-2.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "echo no-lint-yet"
  },
  "dependencies": {
    "@arivie/core": "workspace:*",
    "@mastra/mcp": "1.11.0",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.20.5",
    "typescript": "^6.0.0",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
