{
  "name": "@arivie/example-woocommerce-orders-postgres-kitchen-sink",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "setup-db": "tsx scripts/setup-db.ts",
    "sync": "tsx scripts/sync-orders.ts",
    "sync:incremental": "tsx scripts/sync-orders.ts --mode incremental",
    "validate": "tsx scripts/validate-normalization.ts",
    "api": "tsx scripts/api-server.ts",
    "chat": "tsx scripts/chat.ts",
    "demo": "tsx scripts/run-demo.ts",
    "dry-run": "tsx scripts/dry-run.ts",
    "build:node": "pnpm --filter @arivie/cli build && pnpm exec arivie build --target node --config arivie.config.ts --output dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.64",
    "@arivie/core": "workspace:*",
    "@arivie/db-postgres": "workspace:*",
    "@arivie/plugin-analytics": "workspace:*",
    "@arivie/plugin-postgres": "workspace:*",
    "@hono/node-server": "^1.19.14",
    "hono": "^4.12.0",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@arivie/cli": "workspace:*",
    "@types/node": "^22.0.0",
    "tsx": "^4.20.5",
    "typescript": "^6.0.0"
  }
}
