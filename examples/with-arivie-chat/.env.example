# --- Postgres (Better Auth + Mastra Memory + Arivie semantic execute) ---
DATABASE_URL=postgresql://localhost:5432/arivie_chat

# --- Better Auth ---
# Generate via: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-32-byte-random-string
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Model provider (pick one — auto-resolves in order: google > openai > xai) ---
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash

# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5-mini

# XAI_API_KEY=
# XAI_MODEL=grok-4.20-non-reasoning

# --- Arivie owner / DB role ---
ARIVIE_OWNER_ID=arivie-chat
ARIVIE_OWNER_NAME=Arivie
ARIVIE_DB_ROLE=arivie_reader
